# Copy this file to a private file such as .env.live, fill in real values,
# then load it with: set -a; . ./.env.live; set +a
# Do not commit real Trello credentials.

# Required explicit opt-in for tests that mutate/delete data in Trello.
TRELLO_RUN_LIVE_TESTS=1

# Generate these from a Power-Up API key page in
# https://trello.com/power-ups/admin while signed in to the Trello account
# that owns the disposable test board. Personal keys at https://trello.com/app-key
# are legacy and should only be used as a local-testing fallback.
TRELLO_API_KEY=replace-with-your-key
TRELLO_TOKEN=replace-with-your-token

# Optional prefix for the temporary board created by the live suite.
# The suite appends a random suffix, then deletes the board at process exit.
TRELLO_TEST_BOARD_NAME_PREFIX=py-trello-live-test
